APP_NAME="ShopLaravel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Tunis
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── DATABASE ──────────────────────────────────────────────
# Option 1 : MySQL (XAMPP/WAMP)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shop_ds2
DB_USERNAME=root
DB_PASSWORD=

# Option 2 : SQLite (plus simple pour dev)
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

# ─── MAIL ──────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@shoplaravel.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── CACHE / SESSION ───────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── STORAGE ───────────────────────────────────────────────
FILESYSTEM_DISK=local
